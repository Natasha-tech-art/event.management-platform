[
  {
    "name": "User register",
    "path": "/api/users/register/",
    "method": "POST",
    "role": "public",
    "headers": {"Content-Type": "application/json"},
    "body": {"name": "Alice", "email": "alice@example.com", "password": "StrongPass123", "phone_number": "0712345678"},
    "expected_status": 201,
    "expected_response": {"id": 1, "name": "Alice", "email": "alice@example.com", "phone_number": "0712345678"}
  },
  {
    "name": "User login",
    "path": "/api/users/login/",
    "method": "POST",
    "role": "public",
    "headers": {"Content-Type": "application/json"},
    "body": {"username": "alice", "password": "StrongPass123"},
    "expected_status": 200,
    "expected_response": {"access": "<jwt-access>", "refresh": "<jwt-refresh>"}
  },
  {
    "name": "Refresh token",
    "path": "/api/users/token/refresh/",
    "method": "POST",
    "role": "public",
    "headers": {"Content-Type": "application/json"},
    "body": {"refresh": "<jwt-refresh>"},
    "expected_status": 200,
    "expected_response": {"access": "<new-access>"}
  },
  {
    "name": "Logout",
    "path": "/api/users/logout/",
    "method": "POST",
    "role": "authenticated",
    "headers": {"Authorization": "Bearer <access>", "Content-Type": "application/json"},
    "body": null,
    "expected_status": 204,
    "expected_response": {}
  },
  {
    "name": "Get profile",
    "path": "/api/users/profile/",
    "method": "GET",
    "role": "authenticated",
    "headers": {"Authorization": "Bearer <access>"},
    "body": null,
    "expected_status": 200,
    "expected_response": {"id": 1, "name": "Alice", "email": "alice@example.com", "phone_number": "0712345678"}
  },
  {
