    "path": "/api/users/change-password/",
    "method": "POST",
    "role": "authenticated",
    "headers": {"Authorization": "Bearer <access>", "Content-Type": "application/json"},
    "body": {"old_password": "StrongPass123", "new_password": "NewPass456"},
    "expected_status": 200,
    "expected_response": {"detail": "Password changed successfully."}
  },
  {
